# ── AI Provider ──────────────────────────────────────────────────────────────
# Primary: Gemini (recommended — free tier available)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: choose Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Fallback: Anthropic Claude (if you prefer Claude over Gemini)
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./payops.db

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
